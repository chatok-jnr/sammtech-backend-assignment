generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  boards        Board[]        @relation("BoardOwner")
  refreshTokens RefreshToken[]
  assignedTasks Task[]         @relation("TaskAssignee")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Board {
  id        String    @id @default(uuid())
  title     String
  ownerId   String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  owner   User     @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  columns Column[]

  @@index([ownerId])
  @@map("boards")
}

model Column {
  id        String   @id @default(uuid())
  title     String
  order     Int
  boardId   String
  createdAt DateTime @default(now())

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
  @@map("columns")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  assigneeId  String?
  columnId    String
  position    Int
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  column   Column      @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  labels   TaskLabel[]

  @@index([columnId])
  @@index([priority])
  @@index([dueDate])
  @@map("tasks")
}

model TaskLabel {
  id     String @id @default(uuid())
  name   String
  color  String
  taskId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_labels")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}